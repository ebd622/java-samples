@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml
!define RECTANGLE class
!define INTERFACE interface

' Use straight lines for all connections
skinparam linetype ortho

rectangle "module com.myorg.theApp (app.jar)" as theAppModule {
    package "com.myorg.app" as app{
        RECTANGLE Application
    }
}

rectangle "module com.myorg.theClientAPI (client.jar)" as theClientApiModule {
    package "com.myorg.client" as client {
        RECTANGLE ClientAPI {
            +getHelper(): Helper
        }
        INTERFACE Helper {
            +greet(): void
        }
    }
    package "com.myorg.impl" as impl {
        RECTANGLE HelperImpl {
            +greet(): void
            +secret(): void
        }
    }
}

' Indicate module dependency
' Use a dashed arrow to show that theApp requires theClientAPI

theAppModule .> theClientApiModule : requires

note right of client
  exports com.myorg.client
end note
note top of impl
  opens com.myorg.impl
end note

Application ----> ClientAPI : calls
Application -> Helper : uses
HelperImpl ..|> Helper : implements

' Add free text at the bottom of the diagram
footer Text at the bottom of the diagram
@enduml