@startuml
!include https://raw.githubusercontent.com/plantuml-stdlib/C4-PlantUML/master/C4_Component.puml
!define RECTANGLE class
!define INTERFACE interface

' Use straight lines for all connections
skinparam linetype ortho

rectangle "app.jar" as appJar {
    package "com.myorg.app" as app {
        RECTANGLE Application
    }
}

rectangle "client.jar" as clientJar {
    package "com.myorg.client" as client {
        RECTANGLE ClientAPI
    }
}

' Indicate module dependency
' Use a dashed arrow to show that app.jar requires client.jar

appJar ..> clientJar : requires

Application --> ClientAPI : has

footer Classes from /01 are included. Application has ClientAPI.
@enduml
